# Super Tobi — API Keys
# Copy this to api_keys.env and fill in your keys.
# NEVER commit api_keys.env to git.

# Twitter (twitterapi.io)
TWITTER_API_KEY=your_twitter_api_key

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Google (Gmail, Calendar)
# Download credentials.json from Google Cloud Console
# Run: python scripts/google_auth.py to generate token
GOOGLE_CALENDAR_CREDENTIALS=config/google_credentials.json

# GitHub
GITHUB_PAT=your_github_personal_access_token

# LinkedIn (optional)
LINKEDIN_API_KEY=your_linkedin_key

# Notion (optional)
NOTION_API_KEY=your_notion_key

# Discord (optional)
DISCORD_BOT_TOKEN=your_discord_token

# YouTube (optional)
YOUTUBE_API_KEY=your_youtube_key
